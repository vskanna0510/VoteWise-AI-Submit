# --- Backend API ---
VITE_API_BASE_URL=http://localhost:5000/api

# --- Firebase (Google Auth + Storage) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Google Maps (Checklist iframe — Maps Embed API, not JS SDK) ---
# Create a browser API key (or reuse one whose restrictions allow Maps Embed API).
# GCP: APIs & Services -> enable "Maps Embed API"; Application restrictions -> Websites -> http://localhost:5173/*
# Rebuild frontend or restart vite after changing env (VITE_ vars are compile-time).

VITE_GOOGLE_MAPS_API_KEY=

# --- Google Translate (optional; UI uses POST /api/translate on the backend with GOOGLE_TRANSLATE_API_KEY) ---
# VITE_GOOGLE_TRANSLATE_API_KEY is not read by the app for translation — only set if you add a direct-browser flow.

# --- Google Calendar ---
VITE_GOOGLE_CALENDAR_CLIENT_ID=

# --- Google Analytics ---
VITE_GA_MEASUREMENT_ID=
