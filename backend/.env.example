# --- Server ---
PORT=5000
NODE_ENV=development
# Production: EXACT SPA origin — no trailing slash (e.g. https://vote-wise.vercel.app). Used for CORS.
# Optionally: ADDITIONAL_CORS_ORIGINS=https://vote-wise-git-main-user.vercel.app
# OR set ALLOW_VERCEL_PREVIEW_ORIGINS=true to allow https://*.vercel.app (all preview + prod deployments).
FRONTEND_URL=http://localhost:5173
# --- Database ---
# Atlas: mongodb+srv://USER:URL_ENCODED_PASS@HOST/votewise_ai?options  (encode $ as %24, @ as %40, etc.)
MONGO_URI=mongodb://localhost:27017/votewise_ai

# --- Auth ---
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# --- AI / Google (placeholders, safe to leave blank) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Cloud Translation API v2 — must be Cloud Translation enabled + billing if required by Google project.
GOOGLE_TRANSLATE_API_KEY=

# Keys restricted to "HTTP referrers" block server calls unless Referer matches. We send Referer = this var (preferred) or FRONTEND_URL + "/".
# In GCP credential restrictions include: https://YOUR_APP.vercel.app/* AND https://*.vercel.app/* (previews).
# On Render production: GOOGLE_TRANSLATE_REFERER=https://YOUR_APP.vercel.app/
# GOOGLE_TRANSLATE_REFERER=http://localhost:5173/
# If your key has Application restrictions "None" (API-only), set GOOGLE_TRANSLATE_OMIT_REFERRER=true to omit Referer and avoid referrer-block 403.
# GOOGLE_TRANSLATE_OMIT_REFERRER=true
# --- Default Admin (used by seed) ---
DEFAULT_ADMIN_EMAIL=admin@votewise.ai
DEFAULT_ADMIN_PASSWORD=Admin@123
DEFAULT_ADMIN_NAME=Election Admin
