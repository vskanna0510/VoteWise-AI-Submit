# --- Server ---
PORT=5000
NODE_ENV=development
# Production: EXACT SPA origin — no trailing slash (e.g. https://vote-wise.vercel.app). Used for CORS.
# Optionally: ADDITIONAL_CORS_ORIGINS=https://vote-wise-git-main-user.vercel.app
# OR set ALLOW_VERCEL_PREVIEW_ORIGINS=true to allow https://*.vercel.app (all preview + prod deployments).
FRONTEND_URL=http://localhost:5173
# --- Database ---
# Atlas: mongodb+srv://USER:URL_ENCODED_PASS@HOST/votewise_ai?options  (encode $ as %24, @ as %40, etc.)
MONGO_URI=mongodb://localhost:27017/votewise_ai

# --- Auth ---
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# --- AI / Google (placeholders, safe to leave blank) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Cloud Translation API v2 — must be Cloud Translation enabled + billing if required by Google project.
GOOGLE_TRANSLATE_API_KEY=

# Keys with Application restriction → "HTTP referrers" MUST receive a Referer matching the whitelist — use below.
# In GCP whitelist e.g.: https://YOUR_APP.vercel.app/* and https://*.vercel.app/*
# On Render: GOOGLE_TRANSLATE_REFERER=https://YOUR_APP.vercel.app/
# Leave GOOGLE_TRANSLATE_OMIT_REFERRER unset or false unless you switched the key (see below).
#
# Prefer a SEPARATE backend key: Application restrictions → None ; API restrictions → Cloud Translation API only.
# ONLY then GOOGLE_TRANSLATE_OMIT_REFERRER=true is valid (omit Referer). HTTP-referrer-only keys reject <empty>.
# GOOGLE_TRANSLATE_OMIT_REFERRER=true
# --- Default Admin (used by seed) ---
DEFAULT_ADMIN_EMAIL=admin@votewise.ai
DEFAULT_ADMIN_PASSWORD=Admin@123
DEFAULT_ADMIN_NAME=Election Admin
